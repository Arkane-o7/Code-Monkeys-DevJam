# Enhanced Autonomous AI Web Agent Environment Configuration

# Gemini API Key (required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Specify Gemini model (default: gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# Agent configuration
MAX_RETRIES=3
DEFAULT_TIMEOUT=30000

# Browser configuration
HEADLESS=false
SLOW_MO=100
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Logging
LOG_LEVEL=INFO
LOG_FILE=web_agent.log